{
  "name": "fe-kit-cli",
  "version": "0.0.3",
  "description": "Frontend project scaffold CLI — init, enhance, and manage dev tools, skills, MCP, and framework rules.",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "bin": {
    "fe-kit": "dist/cli.mjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.mjs",
    "typecheck": "tsc --noEmit",
    "bump:version": "node scripts/bump-version.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish",
    "prepublishOnly": "pnpm run build",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cli",
    "frontend",
    "scaffold",
    "vue",
    "react",
    "vite",
    "webpack",
    "rspack",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "deepmerge": "^4.3.1",
    "fs-extra": "^11.3.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.2",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "eslint": "^9.25.0",
    "@eslint/js": "^9.25.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.30.0",
    "prettier": "^3.5.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.0"
  }
}
